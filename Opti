-- BOOSTER DE FPS - BLUE LOCK RIVALS (OPTIMIZADO PARA DELTA)
-- Creado para reducir el lag sin romper el juego

local Settings = {
    LowDetail = true,
    DisableShadows = true,
    RemoveDecals = true,
    ClearParticles = true
}

-- 1. OPTIMIZADOR DE RENDERIZADO
local function Boost()
    local g = game
    local w = g.Workspace
    local l = g.Lighting
    local t = settings().Rendering

    -- Bajar calidad de renderizado al mínimo
    t.QualityLevel = Enum.QualityLevel.Level01
    
    -- Configuración de Iluminación (Adiós lag por sombras)
    if Settings.DisableShadows then
        l.GlobalShadows = false
        l.FogEnd = 9e9
        l.Brightness = 2
    end

    -- Limpieza de Texturas y Efectos en el mapa
    for i, v in pairs(g:GetDescendants()) do
        if Settings.RemoveDecals and (v:IsA("Decal") or v:IsA("Texture")) then
            v:Destroy()
        elseif Settings.ClearParticles and (v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke")) then
            v.Enabled = false
        elseif v:IsA("PostEffect") then -- Quita Bloom, Blur, etc.
            v.Enabled = false
        end
    end
    
    -- Optimizar materiales pesados (Pasto, Metal, etc)
    for i, v in pairs(w:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
        end
    end
end

-- 2. LIMPIADOR DE MEMORIA EN TIEMPO REAL
-- Esto evita que el juego se cierre (Crash) por falta de RAM en el celu
spawn(function()
    while wait(30) do
        collectgarbage("collect")
    end
end)

-- Ejecutar el Boost
print("Optimizador Activado - Blue Lock Rivals")
Boost()

-- Notificación visual en el juego
game.StarterGui:SetCore("SendNotification", {
    Title = "Optimizador Listo";
    Text = "FPS Boosteados. ¡A meter goles, fiera!";
    Duration = 5;
})

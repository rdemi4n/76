-- OPTIMIZADOR INTEGRAL: FPS & NETWORK STABILITY
-- Específico para Blue Lock Rivals

local Settings = {
    LowDetail = true,
    DisableShadows = true,
    NetworkOptimize = true, -- Nueva función para el ping
    ClearGarbage = true
}

-- 1. OPTIMIZACIÓN DE RED (Reducción de Lag de Envío/Recibo)
if Settings.NetworkOptimize then
    -- Ajusta la frecuencia de actualización de red para evitar saturación
    settings().Network.IncomingReplicationLag = 0
    
    -- Intenta priorizar la conexión del juego
    for i, v in pairs(game:GetService("NetworkClient"):GetChildren()) do
        if v:IsA("ClientReplicator") then
            v:SetOutgoingKBPSLimit(900) -- Limita el envío de datos basura
        end
    end
end

-- 2. ELIMINACIÓN DE LAG VISUAL (Mantiene el juego fluido)
local function Boost()
    local g = game
    local l = g.Lighting
    
    -- Forzar calidad mínima
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    l.GlobalShadows = false
    l.FogEnd = 9e9

    -- Borrar efectos pesados que saturan la memoria
    for _, v in pairs(g:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Explosion") then
            v.Enabled = false
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v:Destroy()
        end
    end

    -- Convertir todo a plástico para liberar GPU
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("MeshPart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        end
    end
end

-- 3. ANTI-CRASH (Limpieza de memoria cada 20 segundos)
spawn(function()
    while wait(20) do
        collectgarbage("collect")
        setfpscap(60) -- Mantiene los FPS estables para no forzar la CPU
    end
end)

-- Ejecución
Boost()

game.StarterGui:SetCore("SendNotification", {
    Title = "Opti V2 Activada";
    Text = "FPS & Red optimizados. ¡A jugar!";
    Duration = 5;
})
